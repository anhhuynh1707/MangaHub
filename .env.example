# ============================================================
# MangaHub API - Environment Configuration Example
# Copy this file to .env and update the values for your environment.
# ============================================================

# --- Server Configuration ---
PORT=8080
GIN_MODE=debug # Use 'release' for production

# --- Database Configuration ---
# Relative or absolute path to the SQLite database file
DB_PATH=./data/mangahub.db

# --- Security ---
# REQUIRED — the servers refuse to start without this. Must be at least 16 chars
# and IDENTICAL across the api, tcp, and grpc services. Never commit the real value.
# Generate a strong one with:  openssl rand -base64 48
JWT_SECRET=

# --- Redis Cache Configuration ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Internal Service Ports ---
TCP_PORT=9090
UDP_PORT=9091
GRPC_PORT=9092

# --- Service Feature Flags ---
# Set to 'false' if running these services on a different machine
ENABLE_TCP_SERVER=true
ENABLE_UDP_SERVER=true
ENABLE_GRPC_SERVER=true
