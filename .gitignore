# ========================
# MangaHub .gitignore
# ========================

# --- Environment & Secrets ---
.env
.env.local
.env.*.local

# --- Compiled Binaries ---
*.exe
*.exe~
*.dll
*.so
*.dylib

# --- Database Files ---
data/*.db
data/*.db-shm
data/*.db-wal

# --- Generated Data (re-creatable) ---
data/*.json
data/*_token.txt
data/users/

# --- IDE & Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Go ---
vendor/

# --- Docker ---
docker-compose.override.yml

# --- CLI Config (local sessions) ---
# These are stored in ~/.mangahub/ not in the project,
# but just in case:
profiles/
config.json

# --- Build Binaries ---
*.exe
bin/

# macOS / Linux compiled binaries (no extension).
# Leading slash anchors to repo root so these match ONLY the built binaries,
# NOT the cmd/<name>/ source directories (e.g. cmd/api-server/).
/api-server
/tcp-server
/udp-server
/grpc-server
/tcp-client
/cli
/mangahub
TASKS.html

MangaHub - Manga & Comic Tracking System.html

# --- Claude context & skills (local only, not for GitHub) ---
CLAUDE.md
CLAUDE.local.md
.claude/